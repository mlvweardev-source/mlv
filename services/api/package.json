{
  "name": "@mlv/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "demo:cascade": "ts-node scripts/demo-cascade.ts",
    "demo:shipping": "ts-node scripts/demo-shipping.ts",
    "demo:auth-portal": "ts-node scripts/demo-auth-portal.ts",
    "demo:production-inventory": "ts-node scripts/demo-production-inventory.ts",
    "demo:finance-shipping": "ts-node scripts/demo-finance-shipping.ts",
    "demo:chat-activity": "ts-node scripts/demo-chat-activity.ts",
    "demo:customer-auth": "ts-node scripts/demo-customer-auth.ts",
    "demo:checkout": "ts-node scripts/demo-checkout.ts",
    "demo:customer-chat": "ts-node scripts/demo-customer-chat.ts",
    "verify:bullboard": "ts-node scripts/verify-bullboard.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.0.0",
    "@bull-board/express": "^6.0.0",
    "@mlv/auth": "workspace:*",
    "@mlv/db": "workspace:*",
    "@mlv/types": "workspace:*",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.19.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.4.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
