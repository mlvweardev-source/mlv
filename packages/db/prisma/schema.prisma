// ==============================================
// Prisma Schema — MLV
// Lokasi: packages/db/prisma/schema.prisma
// Ini adalah SATU-SATUNYA lokasi Prisma di monorepo.
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Identity & Access Domain
// ==========================================

/// User internal (Owner, Manajer Produksi, Tim Penjahit)
/// Autentikasi via email + password (JWT), bukan Google.
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hash
  nama      String
  role      UserRole
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@map("users")
}

/// Refresh token untuk staff (Fase 9 — portal internal).
/// Token disimpan sebagai hash SHA-256, bukan plain text.
/// Revocable: logout men-set revoked_at sehingga token tidak bisa dipakai lagi.
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum UserRole {
  OWNER
  MANAJER_PRODUKSI
  TIM_PENJAHIT
}

/// OTP codes untuk autentikasi pelanggan via nomor HP.
/// Kode disimpan sebagai hash, bukan plain text.
model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  codeHash  String   @map("code_hash") // bcrypt hash of OTP code
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, isUsed])
  @@map("otp_codes")
}

// ==========================================
// Customer Domain (§6.1)
// ==========================================

/// Pelanggan — identitas, profil, auth pelanggan
model Customer {
  id        String   @id @default(uuid())
  nama      String
  noHp      String?  @unique @map("no_hp")
  email     String?  @unique
  googleId  String?  @unique @map("google_id")
  alamat    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authMethods CustomerAuthMethod[]
  reviews     Review[]
  orders      Order[]

  @@map("customers")
}

/// Metode autentikasi pelanggan (OTP HP / Google)
model CustomerAuthMethod {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  tipe       CustomerAuthType
  identifier String   // nomor HP atau Google sub ID
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tipe, identifier])
  @@map("customer_auth_methods")
}

enum CustomerAuthType {
  OTP_HP
  GOOGLE
}

/// Review pelanggan setelah order selesai
/// Relasi ke Order Domain akan ditambahkan di Fase 3.
model Review {
  id         String   @id @default(uuid())
  orderId    String?  @map("order_id") // nullable sampai Order Domain ada (Fase 3)
  customerId String   @map("customer_id")
  rating     Int      // 1-5
  komentar   String?
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ==========================================
// Order Domain (§6.2)
// ==========================================

/// Status pesanan — mengikuti alur §25.1
/// Transisi fase ini: Draft → Menunggu Pembayaran DP
enum OrderStatus {
  DRAFT
  MENUNGGU_PEMBAYARAN_DP
  ANTREAN
  CUTTING
  PRINTING
  EMBROIDERY
  SEWING
  FINISHING
  IRONING
  PACKING
  SELESAI
  MENUNGGU_PELUNASAN
  LUNAS
  DIKIRIM
  DIBATALKAN
}

/// Master pesanan
model Order {
  id           String      @id @default(uuid())
  orderNumber  String      @unique @map("order_number") // Human-readable: MLV-YYYYMMDD-XXXX
  customerId   String      @map("customer_id")
  status       OrderStatus @default(DRAFT)
  deadline     DateTime?
  discountNominal Float?   @map("discount_nominal")
  discountPersen    Float?   @map("discount_persen")
  discountApprovedBy String? @map("discount_approved_by")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  customer     Customer    @relation(fields: [customerId], references: [id])
  items        OrderItem[]
  timeline     OrderTimelineEvent[]
  payments     Payment[]
  invoices     Invoice[]
  approvals    Approval[]
  shipments    Shipment[]
  internalChatThread InternalChatThread? // Fase 9.4: chat internal per order (§11)

  @@map("orders")
}

/// Item dalam pesanan (bisa berbagai jenis produk)
model OrderItem {
  id               String   @id @default(uuid())
  orderId          String   @map("order_id")
  productType      String   @map("product_type")
  basePriceSnapshot Float   @default(0) @map("base_price_snapshot")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sizes            OrderSize[]
  designs          OrderDesign[]
  materials        OrderMaterial[]
  services         OrderService[]
  productionTasks  ProductionTask[]

  @@map("order_items")
}

/// Ukuran dan kuantitas per item
model OrderSize {
  id         String   @id @default(uuid())
  orderItemId String  @map("order_item_id")
  ukuran     String
  qty        Int
  createdAt  DateTime @default(now()) @map("created_at")

  orderItem  OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_sizes")
}

/// Desain yang diupload pelanggan
model OrderDesign {
  id                 String   @id @default(uuid())
  orderItemId       String   @map("order_item_id")
  fileUrl           String?  @map("file_url")
  catatanTeks       String?  @map("catatan_teks")
  hasilEkstraksiAi  Json?   @map("hasil_ekstraksi_ai") // Hasil AI Design Analyzer — Fase 12
  statusKonfirmasi  String   @default("MENUNGGU") @map("status_konfirmasi") // MENUNGGU/DITERIMA/DITOLAK
  versiRevisi       Int      @default(1) @map("versi_revisi")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  orderItem         OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_designs")
}

/// Kebutuhan material per item — dihitung otomatis dari BOM × qty
/// BUKAN input manual dari client
/// Relasi ke Material adalah plain foreign key (DDD cross-domain, tidak perlu opposite relation)
model OrderMaterial {
  id           String   @id @default(uuid())
  orderItemId String   @map("order_item_id")
  materialId  String   @map("material_id")
  qtyRequired Float    @map("qty_required")
  createdAt   DateTime @default(now()) @map("created_at")

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([orderItemId, materialId])
  @@map("order_materials")
}

/// Layanan tambahan (bordir, sablon, dll)
model OrderService {
  id           String   @id @default(uuid())
  orderItemId  String   @map("order_item_id")
  serviceType  String   @map("service_type")
  lokasi       String?
  ukuran       String?
  tarif        Float
  createdAt    DateTime @default(now()) @map("created_at")

  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_services")
}

/// Timeline event untuk tracking order (§10)
model OrderTimelineEvent {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  tipeEvent   String   @map("tipe_event")
  deskripsi   String
  actorId     String?  @map("actor_id")
  createdAt   DateTime @default(now()) @map("created_at")

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_timeline_events")
}

// ==========================================
// Inventory Domain (§6.4)
// ==========================================

/// Master data bahan
model Material {
  id        String   @id @default(uuid())
  nama      String
  satuan    String
  kategori  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  billOfMaterials   BillOfMaterial[]
  stockBalances     StockBalance[]
  stockReservations StockReservation[]
  stockMovements    StockMovement[]
  purchaseOrders    PurchaseOrder[]
  stockAdjustments  StockAdjustment[]

  @@map("materials")
}

/// Daftar bahan baku yang dibutuhkan per unit produk (BOM)
model BillOfMaterial {
  id          String   @id @default(uuid())
  productType String   @map("product_type")
  materialId  String   @map("material_id")
  qtyPerUnit  Float    @map("qty_per_unit")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([productType, materialId])
  @@map("bill_of_materials")
}

/// Gudang penyimpanan stok
model Warehouse {
  id        String   @id @default(uuid())
  nama      String
  lokasi    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockBalances  StockBalance[]
  stockMovements StockMovement[]

  @@map("warehouses")
}

/// Cache / agregasi saldo stok saat ini
model StockBalance {
  materialId   String   @map("material_id")
  warehouseId  String   @map("warehouse_id")
  qtyAvailable Float    @default(0) @map("qty_available")
  qtyReserved  Float    @default(0) @map("qty_reserved")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  material  Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([materialId, warehouseId])
  @@map("stock_balances")
}

/// Reservasi stok sementara saat order
model StockReservation {
  id         String                 @id @default(uuid())
  orderId    String                 @map("order_id") // plain string, no relation (DDD cross-domain)
  materialId String                 @map("material_id")
  qty        Float
  status     StockReservationStatus @default(ACTIVE)
  expiresAt  DateTime               @map("expires_at")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("stock_reservations")
}

enum StockReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

/// Log mutasi stok - Sumber kebenaran tunggal
model StockMovement {
  id          String            @id @default(uuid())
  materialId  String            @map("material_id")
  warehouseId String            @map("warehouse_id")
  tipe        StockMovementType
  qty         Float
  refType     String?           @map("ref_type")
  refId       String?           @map("ref_id")
  createdBy   String?           @map("created_by") // plain string, no relation (DDD cross-domain)
  createdAt   DateTime          @default(now()) @map("created_at")

  material  Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

enum StockMovementType {
  IN
  OUT
  RESERVE
  RELEASE
  ADJUST
}

/// Pembelian bahan baku
model PurchaseOrder {
  id         String              @id @default(uuid())
  supplier   String
  materialId String              @map("material_id")
  qty        Float
  totalBiaya Float               @map("total_biaya")
  tglBeli    DateTime            @map("tgl_beli")
  status     PurchaseOrderStatus @default(PENDING)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  PENDING
  COMPLETED
}

/// Penyesuaian stok opname
model StockAdjustment {
  id         String   @id @default(uuid())
  materialId String   @map("material_id")
  qtyDelta   Float    @map("qty_delta")
  alasan     String
  approvedBy String?  @map("approved_by") // plain string, no relation (DDD cross-domain)
  createdAt  DateTime @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("stock_adjustments")
}

// ==========================================
// Finance Domain (§6.5)
// ==========================================

/// Payment record — DP atau Pelunasan
model Payment {
  id              String        @id @default(uuid())
  orderId         String        @map("order_id")
  jenis           PaymentType   // DP atau PELUNASAN
  metode          String        // midtrans, transfer, cash, dll
  jumlah          Float
  status          PaymentStatus @default(PENDING)
  midtransOrderId String?       @map("midtrans_order_id")
  midtransTransactionId String? @map("midtrans_transaction_id")
  webhookEventId  String?       @unique @map("webhook_event_id") // Idempotency
  verifiedAt      DateTime?     @map("verified_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentType {
  DP
  PELUNASAN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

/// Invoice untuk DP dan Pelunasan
model Invoice {
  id          String        @id @default(uuid())
  orderId     String        @map("order_id")
  jenis       InvoiceType   // DP atau PELUNASAN
  jumlah      Float
  status      InvoiceStatus @default(DRAFT)
  pdfUrl      String?       @map("pdf_url")
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

enum InvoiceType {
  DP
  PELUNASAN
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  REFUNDED
}

/// Pembagian hasil manual (Owner input)
model ProfitSharing {
  id          String   @id @default(uuid())
  orderId     String?  @map("order_id") // nullable untuk bagi hasil periodik
  periode     String?  // YYYY-MM untuk bagi hasil periodik
  pihak       String   // nama pihak (owner, manager, penjahit)
  persentase  Float    // 0-100
  nominal     Float?
  catatan     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("profit_sharing")
}

/// Approval workflow untuk harga khusus/diskon/edit invoice/refund
model Approval {
  id          String          @id @default(uuid())
  tipe        ApprovalType
  refId       String?         @map("ref_id") // ID referensi (mis. order_id, invoice_id)
  orderId     String?        @map("order_id") // Order terkait
  requestedBy String          @map("requested_by")
  status      ApprovalStatus  @default(PENDING)
  approvedBy  String?       @map("approved_by")
  catatan     String?
  alasan      String?         // Alasan approval/rejection
  decidedAt   DateTime?     @map("decided_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  order       Order?         @relation(fields: [orderId], references: [id])

  @@map("approvals")
}

enum ApprovalType {
  HARGA_KHUSUS
  DISKON
  EDIT_INVOICE
  REFUND
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==========================================
// Production Domain (§6.3)
// ==========================================

/// Routing proses produksi per jenis produk (ERP: Routing)
/// Template urutan task. Saat OrderConfirmed, task di-instantiate ke production_tasks.
/// NOTE: Ini adalah template tetap, tidak punya relasi langsung ke ProductionTask.
/// Task dibuat berdasarkan array urutanTask, bukan FK.
model ProductionRouting {
  id          String   @id @default(uuid())
  productType String   @unique @map("product_type")
 urutanTask  String[] @map("urutan_task") // Array task_type: ["Cutting","Printing","Sewing",...]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("production_routings")
}

/// Task produksi granular per order item
/// Dibuat otomatis saat OrderConfirmed, dipicu oleh TaskCompleted sebelumnya
model ProductionTask {
  id           String        @id @default(uuid())
  orderItemId  String        @map("order_item_id")
  taskType     TaskType
  sequence     Int           // Urutan dalam routing (1 = pertama, 2 = kedua, dst.)
  status       TaskStatus    @default(DITERIMA)
  assignedTo   String?       @map("assigned_to") // FK ke User.id — plain string (DDD cross-domain)
  startedAt    DateTime?     @map("started_at")
  completedAt  DateTime?     @map("completed_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  orderItem    OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("production_tasks")
}

enum TaskType {
  CUTTING
  PRINTING
  EMBROIDERY
  SEWING
  FINISHING
  IRONING
  PACKING
}

enum TaskStatus {
  DITERIMA      // Siap dikerjakan (task pertama di urutan)
  MENUNGGU     // Menunggu task sebelumnya selesai
  SEDANG_DILAKSANAKAN
  SELESAI
}

// ==========================================
// Shipping Domain (§6.6)
// ==========================================

/// Status pengiriman — mengikuti alur §25.1
enum ShipmentStatus {
  DICATAT      // Shipment baru dicatat, belum handed over ke kurir
  DIKIRIM      // Sudah handed over ke kurir
  DALAM_TRANSIT
  DITERIMA     // Barang diterima pelanggan
}

model Shipment {
  id               String        @id @default(uuid())
  orderId          String        @unique @map("order_id") // Satu shipment per order
  kurir            String        // Nama kurir (JNE, SiCepat, J&T, dll) — input manual
  noResi           String?       @map("no_resi") // Nomor resi — input manual setelah handed over
  status           ShipmentStatus @default(DICATAT)
  alamatPengiriman String?       @map("alamat_pengiriman") // Override alamat customer jika berbeda
  biayaKirim       Float?        @map("biaya_kirim") // Informasional saja, TIDAK diintegrasikan ke Finance
  trackingToken    String        @unique @default(uuid()) @map("tracking_token") // Token unik untuk tracking publik
  shippedAt        DateTime?     @map("shipped_at") // Tanggal handed over ke kurir
  deliveredAt      DateTime?     @map("delivered_at") // Tanggal diterima pelanggan
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipments")
}

// ==========================================
// Notification Domain (§6.7)
// ==========================================

/// Template notifikasi per event type dan channel
model NotificationTemplate {
  id           String               @id @default(uuid())
  eventType    String               @map("event_type")
  channel      NotificationChannel
  templateBody String               @map("template_body") // Template dengan placeholder: {{orderNumber}}, dll
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@unique([eventType, channel])
  @@map("notification_templates")
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  DASHBOARD
  PUSH
}

/// Log pengiriman notifikasi
model NotificationLog {
  id          String              @id @default(uuid())
  customerId  String?             @map("customer_id") // nullable untuk notifikasi internal
  userId      String?             @map("user_id") // nullable untuk notifikasi pelanggan
  orderId     String?             @map("order_id")
  eventType   String?             @map("event_type") // nama event pemicu (mis. payment.succeeded); null untuk dispatch manual tanpa event
  channel     NotificationChannel
  pesan       String
  statusKirim NotificationStatus  @default(PENDING) @map("status_kirim")
  errorMsg    String?             @map("error_msg")
  dedupKey    String?             @map("dedup_key") // hash(eventType+channel+payload) — idempotency konsumen (§16)
  createdAt   DateTime            @default(now()) @map("created_at")

  @@index([dedupKey])
  @@index([userId, createdAt])
  @@map("notification_logs")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ==========================================
// Activity Log (§6.8) — Fase 9 Bagian 4
// ==========================================
// Infrastruktur cross-cutting (BUKAN bounded context sendiri): domain
// manapun boleh memanggil ActivityLogService langsung untuk mencatat
// aktivitas manusiawi yang tampil di UI.
// BEDA dengan Audit Log (§17, forensik, append-only) — dirapikan di Fase 17.

/// Riwayat aktivitas manusiawi (tampil di portal admin)
model ActivityLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id") // null untuk aksi sistem (event processor)
  actorRole  String?  @map("actor_role") // OWNER/MANAJER_PRODUKSI/TIM_PENJAHIT/SYSTEM
  deskripsi  String
  entityType String   @map("entity_type") // mis. 'Order', 'ProductionTask', 'Approval', 'Shipment'
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
  @@map("activity_log")
}

// ==========================================
// Internal Chat (§11) — Fase 9 Bagian 4
// ==========================================
// Chat staf internal per order. BUKAN Customer Portal chat
// (customer_chat_* — tabel berbeda, Fase 10).

/// Thread chat internal — satu per order
model InternalChatThread {
  id        String   @id @default(uuid())
  orderId   String   @unique @map("order_id")
  createdAt DateTime @default(now()) @map("created_at")

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  messages  InternalChatMessage[]

  @@map("internal_chat_threads")
}

/// Pesan dalam thread chat internal
model InternalChatMessage {
  id        String   @id @default(uuid())
  threadId  String   @map("thread_id")
  senderId  String   @map("sender_id") // staff user id
  pesan     String
  createdAt DateTime @default(now()) @map("created_at")

  thread    InternalChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("internal_chat_messages")
}
