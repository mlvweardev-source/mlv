// ==============================================
// Prisma Schema — MLV
// Lokasi: packages/db/prisma/schema.prisma
// Ini adalah SATU-SATUNYA lokasi Prisma di monorepo.
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Identity & Access Domain
// ==========================================

/// User internal (Owner, Manajer Produksi, Tim Penjahit)
/// Autentikasi via email + password (JWT), bukan Google.
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hash
  nama      String
  role      UserRole
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum UserRole {
  OWNER
  MANAJER_PRODUKSI
  TIM_PENJAHIT
}

/// OTP codes untuk autentikasi pelanggan via nomor HP.
/// Kode disimpan sebagai hash, bukan plain text.
model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  codeHash  String   @map("code_hash") // bcrypt hash of OTP code
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, isUsed])
  @@map("otp_codes")
}

// ==========================================
// Customer Domain (§6.1)
// ==========================================

/// Pelanggan — identitas, profil, auth pelanggan
model Customer {
  id        String   @id @default(uuid())
  nama      String
  noHp      String?  @unique @map("no_hp")
  email     String?  @unique
  googleId  String?  @unique @map("google_id")
  alamat    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authMethods CustomerAuthMethod[]
  reviews     Review[]

  @@map("customers")
}

/// Metode autentikasi pelanggan (OTP HP / Google)
model CustomerAuthMethod {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  tipe       CustomerAuthType
  identifier String   // nomor HP atau Google sub ID
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tipe, identifier])
  @@map("customer_auth_methods")
}

enum CustomerAuthType {
  OTP_HP
  GOOGLE
}

/// Review pelanggan setelah order selesai
/// Relasi ke Order Domain akan ditambahkan di Fase 3.
model Review {
  id         String   @id @default(uuid())
  orderId    String?  @map("order_id") // nullable sampai Order Domain ada (Fase 3)
  customerId String   @map("customer_id")
  rating     Int      // 1-5
  komentar   String?
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ==========================================
// Order Domain (§6.2)
// ==========================================

/// Status pesanan — mengikuti alur §25.1
/// Transisi fase ini: Draft → Menunggu Pembayaran DP
enum OrderStatus {
  DRAFT
  MENUNGGU_PEMBAYARAN_DP
  ANTREAN
  CUTTING
  PRINTING
  EMBROIDERY
  SEWING
  FINISHING
  IRONING
  PACKING
  SELESAI
  MENUNGGU_PELUNASAN
  LUNAS
  DIKIRIM
  DIBATALKAN
}

/// Master pesanan
model Order {
  id           String      @id @default(uuid())
  orderNumber  String      @unique @map("order_number") // Human-readable: MLV-YYYYMMDD-XXXX
  customerId   String      @map("customer_id")
  status       OrderStatus @default(DRAFT)
  deadline     DateTime?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  items        OrderItem[]
  timeline     OrderTimelineEvent[]

  @@map("orders")
}

/// Item dalam pesanan (bisa berbagai jenis produk)
model OrderItem {
  id               String   @id @default(uuid())
  orderId          String   @map("order_id")
  productType      String   @map("product_type")
  basePriceSnapshot Float   @default(0) @map("base_price_snapshot")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sizes            OrderSize[]
  designs          OrderDesign[]
  materials        OrderMaterial[]
  services         OrderService[]

  @@map("order_items")
}

/// Ukuran dan kuantitas per item
model OrderSize {
  id         String   @id @default(uuid())
  orderItemId String  @map("order_item_id")
  ukuran     String
  qty        Int
  createdAt  DateTime @default(now()) @map("created_at")

  orderItem  OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_sizes")
}

/// Desain yang diupload pelanggan
model OrderDesign {
  id                 String   @id @default(uuid())
  orderItemId       String   @map("order_item_id")
  fileUrl           String?  @map("file_url")
  catatanTeks       String?  @map("catatan_teks")
  hasilEkstraksiAi  Json?   @map("hasil_ekstraksi_ai") // Hasil AI Design Analyzer — Fase 12
  statusKonfirmasi  String   @default("MENUNGGU") @map("status_konfirmasi") // MENUNGGU/DITERIMA/DITOLAK
  versiRevisi       Int      @default(1) @map("versi_revisi")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  orderItem         OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_designs")
}

/// Kebutuhan material per item — dihitung otomatis dari BOM × qty
/// BUKAN input manual dari client
/// Relasi ke Material adalah plain foreign key (DDD cross-domain, tidak perlu opposite relation)
model OrderMaterial {
  id           String   @id @default(uuid())
  orderItemId String   @map("order_item_id")
  materialId  String   @map("material_id")
  qtyRequired Float    @map("qty_required")
  createdAt   DateTime @default(now()) @map("created_at")

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([orderItemId, materialId])
  @@map("order_materials")
}

/// Layanan tambahan (bordir, sablon, dll)
model OrderService {
  id           String   @id @default(uuid())
  orderItemId  String   @map("order_item_id")
  serviceType  String   @map("service_type")
  lokasi       String?
  ukuran       String?
  tarif        Float
  createdAt    DateTime @default(now()) @map("created_at")

  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_services")
}

/// Timeline event untuk tracking order (§10)
model OrderTimelineEvent {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  tipeEvent   String   @map("tipe_event")
  deskripsi   String
  actorId     String?  @map("actor_id")
  createdAt   DateTime @default(now()) @map("created_at")

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_timeline_events")
}

// ==========================================
// Inventory Domain (§6.4)
// ==========================================

/// Master data bahan
model Material {
  id        String   @id @default(uuid())
  nama      String
  satuan    String
  kategori  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  billOfMaterials   BillOfMaterial[]
  stockBalances     StockBalance[]
  stockReservations StockReservation[]
  stockMovements    StockMovement[]
  purchaseOrders    PurchaseOrder[]
  stockAdjustments  StockAdjustment[]

  @@map("materials")
}

/// Daftar bahan baku yang dibutuhkan per unit produk (BOM)
model BillOfMaterial {
  id          String   @id @default(uuid())
  productType String   @map("product_type")
  materialId  String   @map("material_id")
  qtyPerUnit  Float    @map("qty_per_unit")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([productType, materialId])
  @@map("bill_of_materials")
}

/// Gudang penyimpanan stok
model Warehouse {
  id        String   @id @default(uuid())
  nama      String
  lokasi    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockBalances  StockBalance[]
  stockMovements StockMovement[]

  @@map("warehouses")
}

/// Cache / agregasi saldo stok saat ini
model StockBalance {
  materialId   String   @map("material_id")
  warehouseId  String   @map("warehouse_id")
  qtyAvailable Float    @default(0) @map("qty_available")
  qtyReserved  Float    @default(0) @map("qty_reserved")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  material  Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([materialId, warehouseId])
  @@map("stock_balances")
}

/// Reservasi stok sementara saat order
model StockReservation {
  id         String                 @id @default(uuid())
  orderId    String                 @map("order_id") // plain string, no relation (DDD cross-domain)
  materialId String                 @map("material_id")
  qty        Float
  status     StockReservationStatus @default(ACTIVE)
  expiresAt  DateTime               @map("expires_at")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("stock_reservations")
}

enum StockReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

/// Log mutasi stok - Sumber kebenaran tunggal
model StockMovement {
  id          String            @id @default(uuid())
  materialId  String            @map("material_id")
  warehouseId String            @map("warehouse_id")
  tipe        StockMovementType
  qty         Float
  refType     String?           @map("ref_type")
  refId       String?           @map("ref_id")
  createdBy   String?           @map("created_by") // plain string, no relation (DDD cross-domain)
  createdAt   DateTime          @default(now()) @map("created_at")

  material  Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

enum StockMovementType {
  IN
  OUT
  RESERVE
  RELEASE
  ADJUST
}

/// Pembelian bahan baku
model PurchaseOrder {
  id         String              @id @default(uuid())
  supplier   String
  materialId String              @map("material_id")
  qty        Float
  totalBiaya Float               @map("total_biaya")
  tglBeli    DateTime            @map("tgl_beli")
  status     PurchaseOrderStatus @default(PENDING)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  PENDING
  COMPLETED
}

/// Penyesuaian stok opname
model StockAdjustment {
  id         String   @id @default(uuid())
  materialId String   @map("material_id")
  qtyDelta   Float    @map("qty_delta")
  alasan     String
  approvedBy String?  @map("approved_by") // plain string, no relation (DDD cross-domain)
  createdAt  DateTime @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("stock_adjustments")
}

