# ==============================================
# MLV — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# ==============================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://mlv:mlv_secret@localhost:5432/mlv?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Bull Board (monitoring queue BullMQ — §22, Fase 6)
# Jika BULL_BOARD_PASSWORD kosong, Bull Board dinonaktifkan (fail-closed).
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=CHANGE_ME_bull_board_password

# Service Ports
API_PORT=3000
NOTIFICATION_PORT=3001
AI_GATEWAY_PORT=3002

# JWT (Identity & Access — Fase 1)
JWT_SECRET=CHANGE_ME_to_a_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
# Staff portal (Fase 9): access token pendek + refresh token httpOnly cookie
JWT_ACCESS_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_DAYS=7
# CORS origins untuk apps/web & apps/admin (comma-separated)
CORS_ORIGINS=http://localhost:4000,http://localhost:4001

# Google OAuth (pelanggan — Fase 1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini AI (ONLY used by services/ai-gateway)
GEMINI_API_KEY=

# AI Gateway URL (used by services/api to call ai-gateway for design analysis)
AI_GATEWAY_URL=http://localhost:3002

# Midtrans Payment Gateway (Fase 5)
MIDTRANS_MERCHANT_ID=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SANDBOX_BASE_URL=https://app.sandbox.midtrans.com

# WhatsApp via Fonnte (Fase 8 — provider tidak resmi, keputusan #1)
# Kosongkan FONNTE_API_TOKEN = sandbox mode (pesan hanya di-log, dianggap sukses).
# Isi token dari dashboard Fonnte untuk kirim WA sungguhan.
FONNTE_API_URL=https://api.fonnte.com/send
FONNTE_API_TOKEN=

# WhatsApp Cloud API resmi (future — swap dari Fonnte saat volume naik)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Google Identity Services (Fase 10 - customer portal apps/web)
# Client ID yang SAMA dipakai backend (verifikasi audience) dan frontend (render tombol).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
